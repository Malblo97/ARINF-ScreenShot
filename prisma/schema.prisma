// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model UserAccounts {
  id            Int       @id @default(autoincrement())
  email         String    @unique
  passwordHash  String
  displayName   String
  avatarUrl     String?
  ajUsername    String?
  ajDate        DateTime  @default(now())
  moUser        String?
  moDate        DateTime  @updatedAt
  deletedAt     DateTime?

  AuthSessions  AuthSessions[]
  Projects      Projects[]
  ProjectUsers  ProjectUsers[]
  Invitations   Invitations[]
  ProjectStatusHistories ProjectStatusHistories[]
  SceneElementSnapshots  SceneElementSnapshots[]
  ElementOperations       ElementOperations[]

  @@map("UserAccounts")
}

model AuthSessions {
  id          Int      @id @default(autoincrement())
  token       String   @unique
  deviceInfo  String?
  ipAddress   String?
  expiresAt   DateTime
  ajDate      DateTime @default(now())

  UsAcc_owns_id  Int
  UserAccounts   UserAccounts @relation(fields: [UsAcc_owns_id], references: [id])

  @@map("AuthSessions")
}

model Roles {
  id          Int     @id @default(autoincrement())
  name        String  @unique
  permissions Json?

  ProjectUsers  ProjectUsers[]
  Invitations   Invitations[]

  @@map("Roles")
}

model Projects {
  id           Int       @id @default(autoincrement())
  title        String
  description  String?
  status       String    @default("draft")
  ajUser       String?
  ajDate       DateTime  @default(now())
  moUser       String?
  moDate       DateTime  @updatedAt
  deletedAt    DateTime?

  UsAcc_owner_id  Int
  UserAccounts    UserAccounts @relation(fields: [UsAcc_owner_id], references: [id])

  ProjectUsers            ProjectUsers[]
  Invitations             Invitations[]
  ProjectStatusHistories  ProjectStatusHistories[]
  Scripts                 Scripts[]
  Characters              Characters[]
  SceneComponents         SceneComponents[]

  @@map("Projects")
}

model ProjectUsers {
  id      Int      @id @default(autoincrement())
  ajDate  DateTime @default(now())

  Proj_contains_id  Int
  UsAcc_member_id   Int
  Rol_defines_id    Int

  Projects      Projects      @relation(fields: [Proj_contains_id], references: [id])
  UserAccounts  UserAccounts  @relation(fields: [UsAcc_member_id], references: [id])
  Roles         Roles         @relation(fields: [Rol_defines_id], references: [id])

  PermissionOverrides  PermissionOverrides[]
  Validations          Validations[]
  Comments             Comments[]
  Notes                Notes[]

  @@unique([Proj_contains_id, UsAcc_member_id]) // contrainte d'unicité pour éviter les doublons de membres dans un projet
  @@map("ProjectUsers")
}

model PermissionOverrides {
  id          Int      @id @default(autoincrement())
  entityType  String
  entityId    Int
  permission  String
  granted     Boolean  @default(true)
  ajDate      DateTime @default(now())

  ProUs_detailed_id  Int
  ProjectUsers       ProjectUsers @relation(fields: [ProUs_detailed_id], references: [id])

  @@unique([ProUs_detailed_id, entityType, entityId, permission])
  @@map("PermissionOverrides")
}

model Invitations {
  id          Int      @id @default(autoincrement())
  email       String
  token       String   @unique
  statuts     String   @default("pending")
  expiresAt   DateTime

  Proj_sends_id     Int
  UsAcc_invites_id  Int
  Rol_assigned_id   Int

  Projects      Projects      @relation(fields: [Proj_sends_id], references: [id])
  UserAccounts  UserAccounts  @relation(fields: [UsAcc_invites_id], references: [id])
  Roles         Roles         @relation(fields: [Rol_assigned_id], references: [id])

  @@map("Invitations")
}

model ProjectStatusHistories {
  id          Int      @id @default(autoincrement())
  fromStatus  String?
  toStatus    String
  reason      String?
  ajDate      DateTime @default(now())

  Proj_historical_id  Int
  UsAcc_changes_id    Int

  Projects      Projects      @relation(fields: [Proj_historical_id], references: [id])
  UserAccounts  UserAccounts  @relation(fields: [UsAcc_changes_id], references: [id])
  
  @@map("ProjectStatusHistories")
}

model Scripts {
  id          Int       @id @default(autoincrement())
  title       String
  variant     String    @default("main")
  version     Int       @default(1)
  ajDate      DateTime  @default(now())
  deletedAt   DateTime?

  Proj_contains_id  Int
  Projects          Projects @relation(fields: [Proj_contains_id], references: [id])

  Acts  Acts[]
  Validations          Validations[]

  @@unique([Proj_contains_id, title, variant])
  @@map("Scripts")
}

model Acts {
  id        Int       @id @default(autoincrement())
  title     String
  position  Int
  status    String    @default("draft")
  deletedAt DateTime?

  Scri_contains_id  Int
  Scripts           Scripts @relation(fields: [Scri_contains_id], references: [id])

  Scenes  Scenes[]
  Validations          Validations[]

  @@unique([Scri_contains_id, position])
  @@map("Acts")
}

model Scenes {
  id                  Int       @id @default(autoincrement())
  title               String?
  interiorExterior    String?
  location            String
  timeOfDay           String?
  position            Int
  version             Int       @default(1)
  status              String    @default("draft")
  estimatedPageCount  Int?
  deletedAt           DateTime?

  Act_contains_id  Int
  Acts             Acts @relation(fields: [Act_contains_id], references: [id])

  SceneElements  SceneElements[]
  ComponentAttachments  ComponentAttachments[]
    Validations          Validations[]
    Comments             Comments[]
    Notes                Notes[]

  @@unique([Act_contains_id, position])
  @@map("Scenes")
}

model Characters {
  id           Int       @id @default(autoincrement())
  name         String
  description  String?
  arc          String?
  deletedAt    DateTime?

  Proj_contains_id  Int
  Projects          Projects @relation(fields: [Proj_contains_id], references: [id])

  SceneElements  SceneElements[]

  @@unique([Proj_contains_id, name])
  @@map("Characters")
}

model SceneElements {
  id         Int       @id @default(autoincrement())
  type       String
  content    String?
  position   Int
  version    Int       @default(1)
  deletedAt  DateTime?

  Scen_contains_id  Int
  Scenes            Scenes @relation(fields: [Scen_contains_id], references: [id])

  Scen_parent_id  Int?
  parent          SceneElements?  @relation("DialogLines", fields: [Scen_parent_id], references: [id])
  children        SceneElements[] @relation("DialogLines")

  Char_speaks_id  Int?
  Characters      Characters? @relation(fields: [Char_speaks_id], references: [id])

  SceneElementSnapshots  SceneElementSnapshots[]
  ElementOperations       ElementOperations[]
  ComponentAttachments     ComponentAttachments[]
  Comments                 Comments[]
  Notes                    Notes[]

  @@unique([Scen_contains_id, position])
  @@map("SceneElements")
}

model SceneElementSnapshots {
  id          Int      @id @default(autoincrement())
  version     Int
  content     String?
  changeType  String
  ajDate      DateTime @default(now())

  ScElem_snapshot_id  Int
  SceneElements       SceneElements @relation(fields: [ScElem_snapshot_id], references: [id])

  UsAcc_author_id  Int
  UserAccounts     UserAccounts @relation(fields: [UsAcc_author_id], references: [id])

  @@unique([ScElem_snapshot_id, version])
  @@map("SceneElementSnapshots")
}

model ElementOperations {
  id        Int      @id @default(autoincrement())
  opType    String
  payload   Json
  clock     Int
  applied   Boolean  @default(false)
  ajDate    DateTime @default(now())

  ScElem_operation_id  Int
  SceneElements        SceneElements @relation(fields: [ScElem_operation_id], references: [id])

  UsAcc_author_id  Int
  UserAccounts     UserAccounts @relation(fields: [UsAcc_author_id], references: [id])

  @@map("ElementOperations")
}

model SceneComponents {
  id      Int      @id @default(autoincrement())
  type    String
  label   String
  data    Json
  ajDate  DateTime @default(now())

  Proj_contains_id  Int
  Projects          Projects @relation(fields: [Proj_contains_id], references: [id])

  ComponentAttachments  ComponentAttachments[]

  @@map("SceneComponents")
}

model ComponentAttachments {
  deptId  Int      @default(autoincrement())
  ajDate  DateTime @default(now())

  ScComp_attaches_id  Int
  SceneComponents     SceneComponents @relation(fields: [ScComp_attaches_id], references: [id])

  Scen_target_id  Int?
  Scenes          Scenes? @relation(fields: [Scen_target_id], references: [id])

  ScElem_target_id  Int?
  SceneElements     SceneElements? @relation(fields: [ScElem_target_id], references: [id])

  @@id([ScComp_attaches_id, deptId])
  @@map("ComponentAttachments")
}

model Validations {
  id       Int      @id @default(autoincrement())
  status   String
  comment  String?
  ajDate   DateTime @default(now())

  ProjUs_validates_id  Int
  ProjectUsers         ProjectUsers @relation(fields: [ProjUs_validates_id], references: [id])

  Scen_target_id  Int?
  Scenes          Scenes? @relation(fields: [Scen_target_id], references: [id])

  Act_target_id   Int?
  Acts            Acts? @relation(fields: [Act_target_id], references: [id])

  Scri_target_id  Int?
  Scripts         Scripts? @relation(fields: [Scri_target_id], references: [id])

  Sequ_target_id  Int?
  //Sequencers      Sequencers? @relation(fields: [Sequ_target_id], references: [id])

  @@map("Validations")
}

model Comments {
  id        Int       @id @default(autoincrement())
  content   String
  ajDate    DateTime  @default(now())
  deletedAt DateTime?

  ProjUs_posts_id  Int
  ProjectUsers     ProjectUsers @relation(fields: [ProjUs_posts_id], references: [id])

  Scen_target_id  Int?
  Scenes          Scenes? @relation(fields: [Scen_target_id], references: [id])

  ScElem_target_id  Int?
  SceneElements     SceneElements? @relation(fields: [ScElem_target_id], references: [id])

  DocVers_target_id  Int?
  // FK composite vers DocumentVersions — ajoutée Jour 3 quand cette table existera

  Comm_parent_id  Int?
  parent          Comments?  @relation("CommentReplies", fields: [Comm_parent_id], references: [id])
  replies         Comments[] @relation("CommentReplies")

  @@map("Comments")
}

model Notes {
  id        Int      @id @default(autoincrement())
  content   String
  isPrivate Boolean  @default(true)
  ajDate    DateTime @default(now())

  ProjUs_creates_id  Int
  ProjectUsers       ProjectUsers @relation(fields: [ProjUs_creates_id], references: [id])

  Scen_target_id  Int?
  Scenes          Scenes? @relation(fields: [Scen_target_id], references: [id])

  ScElem_target_id  Int?
  SceneElements     SceneElements? @relation(fields: [ScElem_target_id], references: [id])

  @@map("Notes")
}